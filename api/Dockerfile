FROM python:3.12-slim

WORKDIR /app

ENV PYTHONUNBUFFERED=1 \
    ANIMALES_DB_PATH=/app/animales.db

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app/ ./app/
COPY animales.db.gz ./

EXPOSE 13008

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "13008"]
